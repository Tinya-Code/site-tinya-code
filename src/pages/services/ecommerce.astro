---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/ui/sections/SectionHeader.astro";
import AidaBannerSection from "@/components/smart/AidaBannerSection.astro";
import DepositBadge from "@/components/ui/sections/DepositBadge.astro";
import { services } from "@/data/services";
import { siteConfig } from "@/data/siteConfig";
import { Icon } from "astro-icon/components";
 /* removed */ ;

const { services: servicesLabels } = siteConfig.pages;
const service = services.find((s) => s.id === "ecommerce")!;

const seo = {
  title: `${service.title} — Tinya Code`,
  description: service.description,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  {/* 1. Hero Service (bg-light) */}
  <section class="section-base section-light">
    <div class="container-main grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 bg-brand/10 text-brand rounded-sm text-[10px] font-bold uppercase tracking-widest font-poppins"
        >
          <Icon name={service.icon} class="size-4" />
          {servicesLabels.badge}
        </div>

        <h1 class="text-4xl md:text-6xl font-poppins font-extrabold text-dark leading-tight italic">
          {service.title}
        </h1>

        <p class="text-gray text-lg leading-relaxed font-poppins">
          {service.fullDescription}
        </p>

        <DepositBadge />
      </div>

      <div class="relative rounded-sm overflow-hidden border border-accent/20">
        <img
          src={service.image}
          alt={service.title}
          width={800}
          height={600}
          loading="eager"
          class="w-full h-auto object-cover grayscale hover:grayscale-0 transition-all duration-700"
        />
      </div>
    </div>
  </section>

  {/* 2. Features Grid (bg-white) */}
  <section class="section-base section-white">
    <div class="container-main">
      <SectionHeader title={servicesLabels.featuresTitle} centered={false} />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mt-12">
        {
          service.detailedFeatures.map((feature) => (
            <div class="space-y-4">
              <Icon name={feature.icon} class="size-8 text-brand" />
              <h3 class="text-xl font-bold text-dark font-poppins">{feature.title}</h3>
              <p class="text-gray text-sm leading-relaxed font-poppins">{feature.description}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  {/* 3. Benefits & Audience (bg-dark) */}
  <section class="section-base section-dark">
    <div class="container-main grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <div class="space-y-8">
        <h3 class="text-3xl font-bold italic font-poppins text-white">
          {servicesLabels.benefitsTitle}
        </h3>
        <ul class="space-y-6">
          {
            service.benefits.map((benefit) => (
              <li class="flex items-start gap-3 text-white/80 font-poppins">
                <Icon name="mdi:check" class="size-5 text-brand shrink-0 mt-1" />
                <span>{benefit}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="p-8 md:p-12 border border-brand/30 bg-white/5 rounded-sm space-y-6">
        <h3 class="text-2xl font-bold text-white italic font-poppins">
          {servicesLabels.targetTitle}
        </h3>
        <p class="text-white/80 text-lg leading-relaxed font-poppins">
          {service.targetAudience}
        </p>
        <div class="pt-4 border-t border-white/10">
          <p class="text-sm italic text-white/40 font-poppins">
            {servicesLabels.disclaimer}
          </p>
        </div>
      </div>
    </div>
  </section>

  {/* 4. CTA (bg-brand) */}
  <AidaBannerSection />
</BaseLayout>
