---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TestimonialsGrid from "@/components/smart/TestimonialsGrid.astro";
import AidaBannerSection from "@/components/smart/AidaBannerSection.astro";
import { siteConfig } from "@/data/siteConfig";

const { testimonials } = siteConfig.pages;

const seo = {
  title: `Testimonios — Tinya Code`,
  description: `Lo que dicen nuestros clientes sobre Tinya Code. Casos de éxito en diseño web y desarrollo de software para empresas B2B.`,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  {/* 1. Hero / Header (bg-light) */}
  <section class="section-base section-light">
    <div class="container-main text-center">
      <div class="mb-12">
        <h1 class="titulo-hero mb-4">{testimonials.title}</h1>
        <p class="subtitulo mx-auto">{testimonials.subtitle}</p>
      </div>
    </div>
  </section>

  {/* 2. Grid (bg-white) */}
  <section class="section-base section-white">
    <div class="container-main">
      <TestimonialsGrid />
    </div>
  </section>





  {/* 5. AidaBanner (bg-light) */}
  <AidaBannerSection />
</BaseLayout>
