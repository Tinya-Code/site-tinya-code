---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TestimonialsGrid from "@/components/smart/TestimonialsGrid.astro";
import AidaBannerSection from "@/components/smart/AidaBannerSection.astro";
import { siteConfig } from "@/data/siteConfig";

const { testimonials } = siteConfig.pages;

const seo = {
  title: `Testimonios — Tinya Code`,
  description: `Lo que dicen nuestros clientes sobre Tinya Code. Casos de éxito en diseño web y desarrollo de software para empresas B2B.`,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  {/* 1. Hero / Header (bg-light) */}
  <section class="section-base section-light">
    <div class="container-main text-center">
      <div class="mb-12">
        <h1 class="titulo-hero mb-4">{testimonials.title}</h1>
        <p class="subtitulo mx-auto">{testimonials.subtitle}</p>
      </div>
    </div>
  </section>

  {/* 2. Grid (bg-white) */}
  <section class="section-base section-white">
    <div class="container-main">
      <TestimonialsGrid />
    </div>
  </section>

  {/* 3. Trust Labels (bg-light) */}
  <section class="section-base section-light">
    <div class="container-main">
      <div class="flex flex-wrap justify-center items-center gap-12 md:gap-24 opacity-30 grayscale">
        {
          testimonials.trustLabels.map((label) => (
            <div class="text-2xl font-poppins font-bold uppercase tracking-tighter">{label}</div>
          ))
        }
      </div>
    </div>
  </section>

  {/* 4. Final CTA (bg-dark) */}
  <section class="section-base section-dark">
    <div class="container-main text-center space-y-8">
      <h2 class="text-3xl md:text-4xl font-poppins font-bold italic text-white">
        {testimonials.cta.title}
      </h2>
      <p class="text-white/70 text-lg max-w-2xl mx-auto font-poppins">
        {testimonials.cta.text}
      </p>
      <div class="pt-4">
        <a
          href="/contact"
          class="inline-block bg-brand text-white font-poppins font-bold px-10 py-4 rounded-sm hover:translate-y-[-2px] transition-all duration-200"
        >
          {testimonials.cta.buttonText}
        </a>
      </div>
    </div>
  </section>

  {/* 5. AidaBanner (bg-light) */}
  <AidaBannerSection />
</BaseLayout>
