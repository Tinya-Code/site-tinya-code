---
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogFeed from "@/components/smart/BlogFeed.astro";
import { getCollection } from "astro:content";
import { siteConfig } from "@/data/siteConfig";

const blogLabels = siteConfig.pages.blog;

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
console.log("DEBUG: Posts found in index.astro:", posts.length);

const seo = {
  title: `Blog — Tinya Code`,
  description: `Artículos sobre diseño web profesional, desarrollo de software, automatización y transformación digital para empresas en Lima.`,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  {/* 1. Hero Blog (bg-light) */}
  <section class="section-base section-light pb-0">
    <div class="container-main text-center">
      <div class="mb-12">
        <h1 class="titulo-hero mb-4">{blogLabels.title}</h1>
        <p class="subtitulo mx-auto">{blogLabels.subtitle}</p>
      </div>
    </div>
  </section>

  {/* 2. Blog Grid (bg-white) */}
  <section class="section-base section-white">
    <div class="container-main">
      <BlogFeed />
    </div>
  </section>
</BaseLayout>
