---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContactSection from "@/components/smart/ContactSection.astro";
import { siteConfig } from "@/data/siteConfig";
import SchemaLocalBusiness from "@/components/ui/common/SchemaLocalBusiness.astro";

const { contact: contactLabels } = siteConfig.pages;

const seo = {
  title: `Contacto — Tinya Code`,
  description: `Solicita tu propuesta sin costo. Respondemos en menos de 24 horas con un plan personalizado para tu empresa.`,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  <SchemaLocalBusiness url={seo.canonical} />
  <ContactSection variant="white" isMainHeading = {true} />
</BaseLayout>
