---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/ui/sections/SectionHeader.astro";
import ReasonsGrid from "@/components/smart/ReasonsGrid.astro";
import TeamGrid from "@/components/smart/TeamGrid.astro";
import CallToAction from "@/components/ui/sections/CallToAction.astro";
import { siteConfig } from "@/data/siteConfig";
import PageHero from "@/components/ui/sections/PageHero.astro";
import StatsSection from "@/components/smart/StatsSection.astro";

const { about } = siteConfig.pages;

const seo = {
  title: `Nosotros — Tinya Code`,
  description: `Conoce al equipo detrás de Tinya Code. Diseñadores y desarrolladores especializados en soluciones digitales para empresas B2B en Lima.`,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  {/* 1. Hero "About" (bg-light) */}

  <PageHero categoryLabel="Proyectos" title={about.title} subtitle={about.subtitle} align="left" />
  {/* 2. Manifest / Philosophy (bg-dark) */}
  <section class="section-base py-4 section-dark relative overflow-hidden">
    <div class="container-main relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <SectionHeader title={about.philosophy.title} subtitle={about.philosophy.text1} />
      <StatsSection bandera={true} />
    </div>
  </section>

  {/* 3. Reasons (bg-white) */}
  <section class="section-base section-white">
    <div class="container-main">
      <SectionHeader title={about.reasonsTitle} subtitle={about.reasonsSubtitle} />
      <ReasonsGrid />
    </div>
  </section>

  {/* 4. Team Section (bg-light) */}
  <section class="section-base section-light relative overflow-hidden">
    <div class="container-main">
      <SectionHeader title={about.teamTitle} subtitle={about.teamSubtitle} />
      <TeamGrid />
    </div>
  </section>

  {/* 5. CTA (bg-brand) */}
  <CallToAction {...siteConfig.cta} showDecorations={true} />
</BaseLayout>
