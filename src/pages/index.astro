---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SectionHeader from "@/components/ui/sections/SectionHeader.astro";
import Hero from "@/components/ui/sections/Hero.astro";
import { siteConfig } from "@/data/siteConfig";
import PricingSection from "@/components/smart/PricingSection.astro";
import ServicesGrid from "@/components/smart/ServicesGrid.astro";
import ReasonsGrid from "@/components/smart/ReasonsGrid.astro";
import SectorsGrid from "@/components/smart/SectorsGrid.astro";
import WhyChooseUsSection from "@/components/smart/WhyChooseUsSection.astro";
import MethodologySection from "@/components/smart/MethodologySection.astro";
import TestimonialsGrid from "@/components/smart/TestimonialsGrid.astro";
import StatsSection from "@/components/smart/StatsSection.astro";
import AidaBannerSection from "@/components/smart/AidaBannerSection.astro";
import PortfolioGallery from "@/components/smart/PortfolioGallery.astro";
import ContactForm from "@/components/ui/sections/ContactForm.astro";
import { contactData, socialLinks } from "@/data/social";
import Icon from "@/components/ui/common/Icon.astro";

const seo = {
  title: "Tinya Code — Diseño Web y Software B2B en Lima",
  description:
    "Agencia de diseño web, desarrollo de software y automatización para empresas de construcción, minería e industria en Lima, Perú.",
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};

// Home page uses BaseLayout directly for better control over section backgrounds
---

<BaseLayout {...seo}>
  <!-- 1. Hero Section (bg-light) -->
  <Hero {...siteConfig.hero} />

  <!-- 2. 4 Poderosas Razones (bg-white) -->
  <section class="section-base section-white">
    <div class="container-main">
      <SectionHeader
        title={siteConfig.home.reasons.title}
        subtitle={siteConfig.home.reasons.subtitle}
      />
      <ReasonsGrid />
    </div>
  </section>

  <!-- 3. Servicios destacados (bg-light) 
  <section class="section-base section-light">
    <div class="container-main">
      <SectionHeader
        title={siteConfig.home.services.title}
        subtitle={siteConfig.home.services.subtitle}
      />
      <ServicesGrid />
    </div>
  </section>
-->
  <!-- 4. Por qué elegirnos (bg-white) -->
  <WhyChooseUsSection />

  <!-- 5. Estadísticas (bg-dark) -->
  <StatsSection />

  <!-- 6. Metodología (bg-light) -->
  <MethodologySection />

  <!-- 7. Testimonios destacados (bg-white) -->
  <section class="section-base section-white">
    <div class="container-main">
      <SectionHeader
        title={siteConfig.home.testimonials.title}
        subtitle={siteConfig.home.testimonials.subtitle}
      />
      <TestimonialsGrid />
    </div>
  </section>

  <section id="precio" class="section-base section-light">
    <div class="container-main">
            <SectionHeader
        title={siteConfig.pages.pricing.title}
        centered = {true}
      />
      <PricingSection />
    </div>
  </section>
  <!-- 8. Sectores que Atendemos (bg-light) 
  <section class="section-base section-light">
    <div class="container-main">
      <SectionHeader
        title={siteConfig.home.sectors.title}
        subtitle={siteConfig.home.sectors.subtitle}
      />
      <SectorsGrid />
    </div>
  </section>
-->
  <!-- 9. Portafolio destacado (bg-white) -->
  <section id="portafolio" class="section-base section-white">
    <div class="container-main">
      <SectionHeader
        title={siteConfig.home.portfolio.title}
        subtitle={siteConfig.home.portfolio.subtitle}
      />
      <div class="mt-12">
        <PortfolioGallery />
      </div>
    </div>
  </section>

  <!-- 10. CTA Final / Aida Banner (bg-brand) -->
  <AidaBannerSection />
  <section class="section-base w-full flex flex-col container-main section-white">
    <SectionHeader
      title={siteConfig.pages.contact.title}
      subtitle={siteConfig.pages.contact.subtitle}
    />

    <div class="flex flex-col gap-4 justify-between items-start md:flex-row w-full">
      <div class="lg:col-span-4 rounded-sm  bg-light min-w-60 hidden md:flex md:flex-col p-4  h-auto  space-y-10">
        <div class="space-y-6">
          <h3 class="font-poppins text-sm text-dark uppercase tracking-wider font-semibold ">
            {siteConfig.pages.contact.sidebar}
          </h3>
          <div class="space-y-4">
            <a
              href={`mailto:${contactData.email}`}
              class="flex items-center gap-4 text-gray hover:text-brand transition-colors group"
            >
              <Icon
                name="mdi:email-outline"
                size={5}
                class="text-dark group-hover:text-brand transition-colors"
                ariaHidden={true}
              />
              <span class="text-sm font-poppins font-medium">{contactData.email}</span>
            </a>
            <a
              href={`tel:${contactData.phone}`}
              class="flex items-center gap-4 text-gray hover:text-brand transition-colors group"
            >
              <Icon
                name="mdi:phone-outline"
                size={5}
                class="text-dark group-hover:text-brand transition-colors"
                ariaHidden={true}
              />
              <span class="text-sm font-poppins font-medium">{contactData.phone}</span>
            </a>
            <div class="flex items-center gap-4 text-gray">
              <Icon name="mdi:map-marker-outline" size={5} class="text-dark" ariaHidden={true} />
              <span class="text-sm font-poppins font-medium">{contactData.address} </span>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <h3 class=" font-poppins text-xs text-dark uppercase tracking-wider font-semibold ">
            {siteConfig.pages.contact.social}
          </h3>
          <div class="flex gap-4">
            {
              socialLinks.map((net) => (
                <a
                  href={net.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="size-10 flex items-center justify-center text-dark hover:text-brand transition-colors"
                  aria-label={net.label}
                >
                  <Icon name={net.icon} size={6} ariaHidden={true} />
                </a>
              ))
            }
          </div>
        </div>
      </div>
      <div class="p-4  bg-light rounded-sm w-full">
        <ContactForm
          labels={siteConfig.contactForm.labels}
          placeholders={siteConfig.contactForm.placeholders}
          services={siteConfig.contactForm.services}
        />
      </div>
    </div>
  </section>
</BaseLayout>
