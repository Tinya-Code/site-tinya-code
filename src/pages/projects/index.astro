---
import PageLayout from "@/layouts/PageLayout.astro";
import SectionHeader from "@/components/ui/sections/SectionHeader.astro";
import PortfolioGallery from "@/components/smart/PortfolioGallery.astro";
import CallToAction from "@/components/ui/sections/CallToAction.astro";
import { siteConfig } from "@/data/siteConfig";

const { portfolio: portfolioLabels } = siteConfig.pages;

const seo = {
  title: `Proyectos y Casos de Éxito | ${siteConfig.name}`,
  description: portfolioLabels.subtitle,
};
---

<PageLayout {...seo}>
  <section class="mb-20">
    <SectionHeader
      title={portfolioLabels.title}
      subtitle={portfolioLabels.subtitle}
      centered={true}
    />

    <div class="mt-12">
      <PortfolioGallery />
    </div>
  </section>

  <CallToAction
    title="Tu empresa merece una solución a este nivel"
    subtitle="Hablemos sobre tus objetivos y cómo nuestra tecnología puede alcanzarlos."
    button={{ text: "Iniciar Consulta", href: "/contact" }}
  />
</PageLayout>
