---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PortfolioGallery from "@/components/smart/PortfolioGallery.astro";
import CallToAction from "@/components/ui/sections/CallToAction.astro";
import { siteConfig } from "@/data/siteConfig";
import PageHero from "@/components/ui/sections/PageHero.astro";

const { portfolio } = siteConfig.pages;

const seo = {
  title: `Portafolio — Tinya Code`,
  description: `Proyectos de diseño web, tiendas virtuales y software a medida para empresas de construcción, minería y servicios en Perú.`,
  canonical: new URL(Astro.url.pathname, siteConfig.url).toString(),
};
---

<BaseLayout {...seo}>
  {/* 1. Portfolio Header (bg-light) */}

  <PageHero
  categoryLabel="Proyectos"
  title={portfolio.title}
  subtitle={portfolio.subtitle}
  align="left"
>
</PageHero>

  {/* 2. Portfolio Grid (bg-white) */}
  <section class="section-base section-white">
    <div class="container-main">
      <PortfolioGallery />
    </div>
  </section>

  <CallToAction {...siteConfig.cta} />
</BaseLayout>
