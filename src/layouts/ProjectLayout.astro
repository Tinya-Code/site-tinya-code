---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ProjectGallery from "@/components/ui/gallery/ProjectGallery.astro";
import ImageModal from "@/components/ui/common/ImageModal.astro";
import BackButton from "@/components/ui/buttons/BackButton.astro";
import type { CollectionEntry } from "astro:content";
import { Icon } from "astro-icon/components";
import { siteConfig } from "@/data/siteConfig";
import { blogTerms } from "@/data/blogTerms";
import BlogContentFormatter from "@/components/ui/common/BlogContentFormatter.astro";
import CallToAction from "@/components/ui/sections/CallToAction.astro";


interface Props {
  project: CollectionEntry<"projects">;
}

const { project } = Astro.props;
const { title, description, heroImage, secondaryImage, imageLayout, images, galleryLayout, galleryDirection, gallerySpeed, category, client, technologies, demo } = project.data;

// Use first gallery image as hero if no heroImage is provided
const mainImage = heroImage || (images && images.length > 0 ? images[0].src : '/generico.jpeg');

const seo = {
  title: `${title} | Casos de Éxito ${siteConfig.name}`,
  description: description,
};
---

<BaseLayout title={seo.title} description={seo.description}>
  <section class="section-base  section-light">
    <article class=" bg-light  mx-auto ">
      <BackButton href="/portfolio" label="Volver a Portafolio" />

      <header class="grid grid-cols-1 container-main lg:grid-cols-2 gap-12 items-center mb-16">
        <div class="space-y-2">
          <div
            class="texto-label text-brand inline-flex items-center gap-2"
          >
            <Icon name="mdi:briefcase-check-outline" class="size-4" />
            Caso de Éxito / {category}
          </div>
          <h1
            class="titulo-seccion italic"
          >
            {title}
          </h1>
          <p class="texto-cuerpo text-gray leading-relaxed">
            {description}
          </p>

          <div class="grid grid-cols-2 gap-8 pt-6 border-t border-accent/20">
            {
              client && (
                <div class="space-y-1">
                  <span class="texto-label text-gray opacity-60">
                    Cliente
                  </span>
                  <p class="font-poppins font-semibold text-dark">{client}</p>
                </div>
              )
            }
            <div class="space-y-1">
              <span
                class="texto-label text-gray opacity-60"
                >Categoría</span
              >
              <p class="font-poppins font-semibold text-dark">{category}</p>
            </div>
            {
              technologies && (
                <div class="col-span-2 space-y-2">
                  <span class="texto-label text-gray opacity-60">
                    Stack Tecnológico
                  </span>
                  <div class="flex flex-wrap gap-2">
                    {technologies.map((tech) => (
                      <span class="px-2 py-0.5 bg-white border border-accent/20 text-dark text-[10px] font-poppins font-bold rounded-sm tracking-wide">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              )
            }
            {
              demo && (
                <div class="col-span-2 pt-4">
                  <a 
                    href={demo} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="btn-primary"
                  >
                    <Icon name="mdi:launch" class="size-4" />
                    Visitar Sitio En Vivo
                  </a>
                </div>
              )
            }
          </div>
        </div>

        <div 
          class="relative rounded-sm overflow-hidden border border-gray-light bg-light/50 group transition-all duration-500 cursor-zoom-in"
          data-image-modal="project-zoom"
          data-src={mainImage}
          data-alt={title}
        >
          <img
            src={mainImage}
            alt={title}
            width="1200"
            height="600"
            loading="eager"
            class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-700 aspect-video md:aspect-[21/9]"
          />
          <div class="absolute inset-0 bg-dark/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
            <span class="text-white font-poppins text-[10px] font-bold uppercase tracking-widest bg-dark/40 backdrop-blur-sm px-4 py-2 rounded-sm border border-white/10">Ampliar imagen</span>
          </div>
        </div>
      </header>
      <main class="bg-white py-4 ">

                <BlogContentFormatter blogTerms={blogTerms}>
            <slot />
          </BlogContentFormatter>

        {images && images.length > 0 && (
          <div class="mt-20">
            <h2 class="titulo-seccion container-main mb-8 italic">Galería del Proyecto</h2>
            <ProjectGallery 
              images={images} 
              layout={galleryLayout} 
              direction={galleryDirection}
              speed={gallerySpeed}
            />
          </div>
        )}

      <CallToAction
        title="¿Listo para lograr resultados similares?"
        subtitle="Cada proyecto es único. Hablemos sobre cómo podemos aplicar nuestra experiencia para solucionar tus desafíos específicos."
        buttonText="Iniciar mi Proyecto"
        buttonHref="/contact"
        background="brand"
      />
      </main>

    </article>
  </section>
  
  <ImageModal id="project-zoom" />
</BaseLayout>
