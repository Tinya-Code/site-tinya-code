---
import BaseHead from "@/components/ui/common/BaseHead.astro";
import Navbar from "@/components/ui/common/Navbar.astro";
import Footer from "@/components/ui/common/Footer.astro";
import WhatsAppButton from "@/components/ui/common/WhatsAppButton.astro";
import ScrollToTop from "@/components/ui/common/ScrollToTop.astro";
import SchemaOrganization from "@/components/ui/common/SchemaOrganization.astro";
import { siteConfig } from "@/data/siteConfig";
import { navLinks, footerLinks } from "@/data/navigation";
import { socialLinks, contactData } from "@/data/social";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: "website" | "article";
  noindex?: boolean;
}

const {
  title,
  description = siteConfig.description,
  canonical,
  ogImage = siteConfig.ogImage,
  ogType = "website",
  noindex = false,
} = Astro.props;

// Prepare social URLs for schema
const socialUrls = socialLinks.map((link) => link.href);
---

<!doctype html>
<html lang={siteConfig.defaultLanguage}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/logonegro.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="RSS Feed" href="/rss.xml" />

    <BaseHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      canonical={canonical}
      noindex={noindex}
      siteName={siteConfig.name}
    />

    <SchemaOrganization
      name={siteConfig.name}
      url={siteConfig.url}
      description={siteConfig.description}
      socialLinks={socialUrls}
    />
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4682284022558576"
     crossorigin="anonymous"></script>
  </head>
  <body class="bg-white text-dark antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4
             focus:z-[100] focus:bg-white focus:border focus:border-brand
             focus:rounded-sm focus:px-4 focus:py-2
             focus:font-poppins focus:text-sm focus:font-semibold focus:text-brand
             focus:shadow-md transition-all"
    >
      Ir al contenido principal
    </a>
    <Navbar navLinks={navLinks} siteName={siteConfig.name} />
    <main id="main-content">
      <slot />
    </main>
    <Footer
      footerLinks={footerLinks}
      siteName={siteConfig.name}
      siteDescription={siteConfig.description}
      socialLinks={socialLinks}
      contactData={contactData}
      footerColumns={siteConfig.footer.columns}
      copyrightText={siteConfig.footer.copyright}
    />
    <WhatsAppButton />
    <ScrollToTop />
  </body>
</html>
