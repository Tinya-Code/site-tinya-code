---
import Button from "@/components/ui/buttons/Button.astro";
import { Image } from "astro:assets";

import type { HeadingTag } from "@/types";

interface Partner {
  name: string;
  logo: string;
}

interface Props {
  categoryLabel: string;
  title: string;
  headingTag?: HeadingTag;
  subtitle: string;
  primaryButton: {
    text: string;
    href: string;
  };
  secondaryButton: {
    text: string;
    href: string;
  };
  image: string;
  metric: {
    value: string;
    label: string;
  };
  partners?: Partner[];
}

const {
  categoryLabel,
  title,
  headingTag: Tag = "h1",
  subtitle,
  primaryButton,
  secondaryButton,
  image,
  metric,
  partners = [
    { name: "Partner 1", logo: "/logos/logo-repiit.svg" },
    { name: "Partner 2", logo: "/logos/logo-travel.webp" },
    { name: "Partner 3", logo: "/logos/logo-amira.png" },
  ],
} = Astro.props;
---

<section class="section-base py-6  section-light overflow-hidden ">
  <div class="container-main grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 items-center">
    <!-- Content -->
    <div class="text-center lg:text-left order-2 lg:order-1">
      <!-- Category Label -->
      <div class="flex items-center justify-center lg:justify-start gap-3 mb-6">
        <span class="border-t border-brand w-8"></span>
        <span class="font-poppins text-xs font-semibold uppercase tracking-widest text-brand">
          {categoryLabel}
        </span>
      </div>

      <Tag class="titulo-hero mb-6">
        {title}
      </Tag>
      <p class="font-poppins text-lg font-medium text-gray mb-8 max-w-xl mx-auto lg:mx-0">
        {subtitle}
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
        <Button href={primaryButton.href}>
          {primaryButton.text}
        </Button>
        <Button href={secondaryButton.href} variant="outline">
          {secondaryButton.text}
        </Button>
      </div>

      <!-- Trust Row -->
      <div class="flex items-center gap-6 mt-12 flex-wrap justify-center lg:justify-start">
        <span class="font-poppins text-xs font-medium text-gray/60 uppercase tracking-wider"
          >Empresas que confían:</span
        >
        <div class="flex items-center gap-4 opacity-40 grayscale">
          {
            partners.map((partner) => (
              <Image
                src={partner.logo}
                alt={partner.name}
                width={80}
                height={32}
                loading="eager"
                aria-hidden="true"
                class="h-6 w-auto object-contain"
              />
            ))
          }
        </div>
      </div>
    </div>

    <!-- Image + Metric -->
    <div class="order-2 lg:order-2 relative group">
      <Image
        src={image}
        alt={title}
        width={800}
        height={800}
        loading="eager"
        class="w-full h-full aspect-square object-cover transition-transform duration-500"
      />
      <div
        class="absolute inset-0  pointer-events-none"
      >
      </div>

      <!-- Metric Card -->
      <div
        class="absolute -bottom-6 -left-6 bg-white border border-gray-light rounded-sm p-6 shadow-sm animate-on-scroll"
        style="animation-delay: 400ms"
      >
        <div class="flex flex-col">
          <span class="font-poppins text-4xl font-bold text-brand leading-none mb-1"
            >{metric.value}</span
          >
          <span class="font-poppins text-xs font-semibold text-gray uppercase tracking-widest"
            >{metric.label}</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
