---
interface Stat {
  value: string;
  label: string;
}

interface Props {
  stats: Stat[];
  bandera:boolean;
}

const { stats, bandera } = Astro.props;
---

<div class="relative px-6 rounded-sm  section-stats-bg ">
  <div
    class={` ${bandera ? " grid-cols-2  ": "grid-cols-2 lg:grid-cols-4 lg:divide-y-0 lg:divide-x divide-accent/30 "} grid   text-center relative z-10`}
  >
    {
      stats.slice(0, 4).map((stat) => {
        const match = stat.value.match(/^(\d+)(.*)$/);
        const target = match ? match[1] : "0";
        const suffix = match ? match[2] : "";

        return (
          <div class="px-8 py-4">
            <div class="font-poppins text-4xl lg:text-4xl font-bold text-accent mb-2 flex items-baseline justify-center">
              <span class="stat-number" data-target={target}>
                0
              </span>
              {suffix && <span class="text-2xl font-bold text-brand ml-0.5">{suffix}</span>}
            </div>
            <div class="font-poppins text-xs font-semibold text-white/40 uppercase tracking-widest mt-2">
              {stat.label}
            </div>
          </div>
        );
      })
    }
  </div>
</div>
