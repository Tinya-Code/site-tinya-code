---
import PricingCard from "@/components/ui/cards/PricingCard.astro";
import Modal from "@/components/ui/common/Modal.astro";
import PricingContactForm from "@/components/ui/sections/PricingContactForm.astro";
import { siteConfig } from "@/data/siteConfig";
import type { ComponentProps } from "astro/types";

interface Props {
  plans: ComponentProps<typeof PricingCard>[];
}

const { plans } = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 lg:gap-6 py-8">
  {
    plans.map((plan, index) => (
      <div class:list={["animate-on-scroll", `animate-delay-${(index % 3) + 1}`]}>
        <PricingCard {...plan} />
      </div>
    ))
  }
</div>

{/* Global Pricing Modal */}
<Modal id="pricingRequestModal">
  <PricingContactForm 
    labels={siteConfig.contactForm.labels} 
    placeholders={siteConfig.contactForm.placeholders} 
  />
</Modal>

<script>
  import { initScrollAnimations } from "@/scripts/observer";

  const initPricingTable = () => {
    initScrollAnimations();

    const triggers = document.querySelectorAll('.pricing-modal-trigger');
    const modal = document.getElementById('pricingRequestModal') as HTMLDialogElement;

    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const plan = trigger.getAttribute('data-plan-name');
        
        // Dispatch custom event to let the form know which plan was selected
        document.dispatchEvent(new CustomEvent('open-pricing-modal', {
          detail: { plan }
        }));

        modal?.showModal();
      });
    });
  };

  initPricingTable();
  document.addEventListener("astro:after-swap", initPricingTable);
</script>
