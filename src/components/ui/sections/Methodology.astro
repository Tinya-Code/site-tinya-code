---
import { Icon } from "astro-icon/components";

interface Phase {
  step: string;
  title: string;
  description: string;
  icon: string;
  image?: string;
}

interface Props {
  phases: Phase[];
  autoplayMs?: number;
  dark?: boolean;
}

const { phases, autoplayMs = 20000, dark = false } = Astro.props;

const bg     = dark ? "bg-dark"         : "bg-white";
const bgSoft = dark ? "bg-white/5"      : "bg-light";
const text   = dark ? "text-white"      : "text-dark";
const textMuted = dark ? "text-white/50" : "text-gray";
const border = dark ? "border-white/10" : "border-gray-light";
const iconBg = dark ? "bg-brand/15"     : "bg-brand/8";
---

<!-- ══ MOBILE ══ -->
<div class="md:hidden flex flex-col w-full divide-y divide-gray-light/60">
  {phases.map((phase, index) => (
    <div
      class="mobile-phase-card group flex items-stretch gap-0 overflow-hidden transition-all duration-500"
      data-index={index}
    >
      <!-- Imagen -->
      <div class="mobile-phase-img w-0 shrink-0 overflow-hidden transition-[width] duration-500">
        {phase.image ? (
          <img
            src={phase.image}
            alt={phase.title}
            class="w-full h-full object-cover"
            loading={index === 0 ? "eager" : "lazy"}
          />
        ) : (
          <div class={`w-full h-full ${bgSoft} flex items-center justify-center`}>
            <Icon name={phase.icon} class="size-5 text-brand/30" />
          </div>
        )}
      </div>

      <!-- Contenido -->
      <div class={`flex flex-col justify-center gap-2 px-5 py-5 flex-1 min-w-0 ${bg}`}>
        <!-- Step + icon -->
        <div class="flex items-center gap-2">
          <span class={`font-rader text-sm font-bold ${textMuted}`}>
            {phase.step}
          </span>
          <div class={`w-1 h-1 rounded-full bg-brand/30`}></div>
          <div class={`p-1.5 rounded-sm ${iconBg}`}>
            <Icon name={phase.icon} class="size-3.5 text-brand" />
          </div>
        </div>

        <h3 class={`font-rader italic text-xl ${text} leading-snug`}>
          {phase.title}
        </h3>

        <p class={`mobile-phase-desc font-poppins text-xs ${textMuted} leading-relaxed max-h-0 opacity-0 overflow-hidden transition-[max-height,opacity] duration-500`}>
          {phase.description}
        </p>
      </div>
    </div>
  ))}
</div>

<!-- ══ DESKTOP ══ -->
<div
  class={`methodology-accordion hidden md:flex items-stretch gap-1.5 w-full ${bg}`}
  data-autoplay={autoplayMs}
  role="tablist"
>
  {phases.map((phase, index) => (
    <button
      class:list={[
        "methodology-item",
        "group relative flex items-stretch text-left cursor-pointer outline-none",
        "overflow-hidden rounded-sm",
        border,
        "",
        "focus-visible:ring-2 focus-visible:ring-brand/40",
      ]}
      data-index={index}
      role="tab"
      aria-selected={index === 0 ? "true" : "false"}
    >

      <!-- Imagen -->
      <div class="methodology-img-wrap shrink-0 overflow-hidden">
        {phase.image ? (
          <img
            src={phase.image}
            alt={phase.title}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            loading={index === 0 ? "eager" : "lazy"}
          />
        ) : (
          <div class={`w-full h-full ${bgSoft} flex items-center justify-center`}>
            <Icon name={phase.icon} class="methodology-placeholder-icon size-5 text-brand/20 transition-all duration-500" />
          </div>
        )}
      </div>

      <!-- Contenido expandido -->
      <div class={`methodology-content flex flex-col gap-3 overflow-hidden ${bg} relative`}>

        <!-- Ícono decorativo de fondo -->
        <Icon
          name={phase.icon}
          class={`absolute -right-4 -bottom-4 size-48 ${dark ? "text-white/[0.03]" : "text-brand/[0.06]"} pointer-events-none select-none transition-opacity duration-500`}
        />

        <div class="relative z-10 flex flex-col gap-3 px-6 py-6 h-full">

          <!-- Step + icon -->
          <div class="flex items-center gap-2.5">
            <span class={`font-rader text-xs font-bold tracking-widest uppercase ${textMuted}`}>
              {phase.step}
            </span>
            <div class="w-4 h-px bg-brand/20"></div>
            <div class={`p-1.5 rounded-sm ${iconBg} border ${dark ? "border-white/5" : "border-brand/10"}`}>
              <Icon name={phase.icon} class="size-3.5 text-brand" />
            </div>
          </div>

          <!-- Título -->
          <h3 class={`font-rader italic text-2xl lg:text-3xl ${text} leading-snug`}>
            {phase.title}
          </h3>

          <!-- Descripción -->
          <p class={`methodology-desc font-poppins text-xs lg:text-sm ${textMuted} leading-relaxed overflow-hidden`}>
            {phase.description}
          </p>

        </div>
      </div>

      <!-- Label colapsado -->
      <div class={`methodology-collapsed absolute inset-0 z-10 flex flex-col items-center justify-center gap-3 pointer-events-none select-none ${bg} transition-opacity duration-300`}>
        <span class={`font-rader text-lg font-bold ${textMuted}`}>
          {phase.step}
        </span>
        <div class="w-px h-4 bg-brand/20"></div>
        <Icon name={phase.icon} class="size-4 text-brand/40" />
        <span class={`font-poppins text-[10px] font-semibold ${textMuted} [writing-mode:vertical-lr] rotate-180 whitespace-nowrap tracking-widest uppercase mt-1`}>
          {phase.title}
        </span>
      </div>

      <!-- Barra de progreso inferior -->
      <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-brand/10 overflow-hidden z-20">
        <div class="methodology-progress-bar h-full bg-brand w-0 origin-left" />
      </div>

    </button>
  ))}
</div>

<style>
  @media (min-width: 768px) {
    .methodology-accordion { height: 380px; }

    .methodology-item {
      flex: 0 0 44px;
      transition: flex 0.6s cubic-bezier(0.4, 0, 0.2, 1), border-color 0.3s ease;
    }
    .methodology-item.is-active { flex: 1 1 0%; }

    /* Imagen */
    .methodology-item .methodology-img-wrap {
      width: 0;
      transition: width 0.55s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .methodology-item.is-active .methodology-img-wrap { width: 320px; }

    /* Contenido */
    .methodology-item .methodology-content {
      width: 0;
      opacity: 0;
      pointer-events: none;
      transition: width 0.5s ease, opacity 0.25s ease;
    }
    .methodology-item.is-active .methodology-content {
      width: auto;
      min-width: 180px;
      opacity: 1;
      pointer-events: auto;
      transition: width 0.55s ease, opacity 0.35s ease 0.15s;
    }

    /* Descripción */
    .methodology-item .methodology-desc {
      max-height: 0;
      opacity: 0;
      transition: max-height 0.35s ease, opacity 0.25s ease;
    }
    .methodology-item.is-active .methodology-desc {
      max-height: 180px;
      opacity: 1;
      transition: max-height 0.45s ease 0.15s, opacity 0.3s ease 0.2s;
    }

    /* Placeholder icon */
    .methodology-item.is-active .methodology-placeholder-icon {
      width: 2.5rem;
      height: 2.5rem;
      color: rgb(var(--color-brand) / 0.3);
    }

    /* Collapsed */
    .methodology-item.is-active .methodology-collapsed  { opacity: 0; pointer-events: none; }
    .methodology-item:not(.is-active) .methodology-collapsed { opacity: 1; }
  }

  /* Activo */
  .methodology-item.is-active {
    border-color: rgb(var(--color-brand) / 0.6);
  }

  /* Progreso */
  .methodology-item.is-active .methodology-progress-bar {
    animation: meth-prog var(--autoplay-ms, 20000ms) linear forwards;
  }
  .methodology-accordion.is-paused .methodology-progress-bar {
    animation-play-state: paused;
  }
  @keyframes meth-prog { to { width: 100%; } }

  /* Mobile activa */
  .mobile-phase-card.is-visible .mobile-phase-img { width: 11rem; }
  .mobile-phase-card.is-visible .mobile-phase-desc {
    max-height: 120px;
    opacity: 1;
  }
</style>

<script>
  function initMobile() {
    const cards = document.querySelectorAll<HTMLElement>(".mobile-phase-card");
    if (!cards.length) return;

    const obs = new IntersectionObserver(
      (entries) => entries.forEach((e) =>
        e.target.classList.toggle("is-visible", e.isIntersecting)
      ),
      { threshold: 0.10 }
    );

    cards.forEach((c) => obs.observe(c));
  }

  function initDesktop() {
    document.querySelectorAll<HTMLElement>(".methodology-accordion").forEach((root) => {
      const clone = root.cloneNode(true) as HTMLElement;
      root.parentNode!.replaceChild(clone, root);

      const items = Array.from(clone.querySelectorAll<HTMLElement>(".methodology-item"));
      const ms    = parseInt(clone.dataset.autoplay ?? "20000", 10);
      let cur = 0, timer: ReturnType<typeof setInterval> | null = null, paused = false;

      clone.style.setProperty("--autoplay-ms", `${ms}ms`);

      const resetBar = (el: HTMLElement) => {
        const b = el.querySelector<HTMLElement>(".methodology-progress-bar");
        if (!b) return;
        b.style.animation = "none";
        void b.offsetWidth;
        b.style.animation = "";
      };

      const activate = (i: number) => {
        items.forEach((item, idx) => {
          const on = idx === i;
          item.classList.toggle("is-active", on);
          item.setAttribute("aria-selected", String(on));
          resetBar(item);
        });
        cur = i;
      };

      const start = () => {
        if (timer) clearInterval(timer);
        timer = setInterval(() => activate((cur + 1) % items.length), ms);
      };
      const stop = () => { if (timer) { clearInterval(timer); timer = null; } };

      items.forEach((item, i) => {
        item.addEventListener("mouseenter", () => { stop(); activate(i); });
        item.addEventListener("mouseleave", () => { if (!paused) start(); });

        item.addEventListener("click", () => {
          if (i === cur && paused) {
            paused = false;
            clone.classList.remove("is-paused");
            start();
          } else {
            paused = true;
            clone.classList.add("is-paused");
            stop();
            activate(i);
          }
        });

        item.addEventListener("keydown", (e: KeyboardEvent) => {
          const map: Record<string, number> = {
            ArrowRight: (i + 1) % items.length,
            ArrowLeft:  (i - 1 + items.length) % items.length,
          };
          if (!(e.key in map)) return;
          e.preventDefault();
          activate(map[e.key]!);
          items[map[e.key]!].focus();
          stop(); start();
        });
      });

      document.addEventListener("visibilitychange", () =>
        document.hidden ? stop() : (!paused && start())
      );

      activate(0);
      start();
    });
  }

  function init() { initMobile(); initDesktop(); }
  init();
  document.addEventListener("astro:after-swap", init);
</script>