---
import { Icon } from "astro-icon/components";
import { contactData } from "@/data/social";

interface Props {
  className?: string;
  messages?: string[];
}

const {
  className = "",
  messages = [
    "¡Hablemos hoy! 💬",
    "¿Tienes un proyecto? ✨",
    "Respuesta rápida garantizada ⚡",
    "Cotiza gratis aquí 🎯",
    "¿En qué te ayudamos? 🙌",
  ],
} = Astro.props;

// Format WhatsApp URL to include the number from contactData
const whatsappUrl = `https://wa.me/${contactData.whatsapp.replace(/\+/g, "").replace(/\s/g, "")}`;
---

<div class="fixed bottom-6 right-6 z-[60] flex items-end gap-3">
  <!-- Nudge bubble -->
  <div
    id="whatsapp-nudge"
    class="whatsapp-nudge relative hidden max-w-[180px] rounded-sm bg-white px-4 py-2.5 shadow-xl border border-gray-light"
    aria-live="polite"
    aria-atomic="true"
  >
    <!-- Arrow pointing right -->
    <div class="absolute right-[-8px] top-1/2 -translate-y-1/2 border-8 border-transparent border-l-white"></div>
    <p id="whatsapp-nudge-text" class="font-poppins text-xs font-semibold text-dark leading-snug"></p>
  </div>

  <!-- WhatsApp anchor -->
  <a
    href={whatsappUrl}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      "flex items-center gap-2",
      "bg-[#25D366] text-white",
      "font-poppins text-xs font-bold uppercase tracking-widest",
      "px-4 py-3 rounded-sm shadow-lg hover:shadow-xl",
      "transition-all duration-300 transform hover:-translate-y-1",
      "focus:ring-2 focus:ring-[#25D366] focus:ring-offset-2 focus:outline-none",
      className,
    ]}
    aria-label="Contactar por WhatsApp"
  >
    <Icon name="mdi:whatsapp" class="size-5" />
    <span class="hidden sm:inline">WhatsApp</span>
  </a>
</div>

<style>
  .whatsapp-nudge {
    animation: nudge-in 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  }

  .whatsapp-nudge.hiding {
    animation: nudge-out 0.3s ease-in forwards;
  }

  @keyframes nudge-in {
    from {
      opacity: 0;
      transform: translateX(12px) scale(0.95);
    }
    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes nudge-out {
    from {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
    to {
      opacity: 0;
      transform: translateX(8px) scale(0.95);
    }
  }
</style>

<script define:vars={{ messages }}>
  const nudge = document.getElementById("whatsapp-nudge");
  const nudgeText = document.getElementById("whatsapp-nudge-text");

  if (!nudge || !nudgeText) return;

  let currentIndex = Math.floor(Math.random() * messages.length);
  let cycleTimeout = null;

  const showNudge = () => {
    // Pick next message
    nudgeText.textContent = messages[currentIndex];
    currentIndex = (currentIndex + 1) % messages.length;

    // Show the bubble
    nudge.classList.remove("hidden", "hiding");

    // Hide after 4 seconds
    cycleTimeout = setTimeout(() => {
      nudge.classList.add("hiding");
      nudge.addEventListener(
        "animationend",
        () => {
          nudge.classList.add("hidden");
          // Show the next one after a pause
          cycleTimeout = setTimeout(showNudge, 8000);
        },
        { once: true }
      );
    }, 4000);
  };

  // Start after a short delay so it doesn't distract immediately on load
  const initialDelay = setTimeout(showNudge, 5000);

  // Cleanup on page transitions
  document.addEventListener("astro:before-swap", () => {
    clearTimeout(initialDelay);
    clearTimeout(cycleTimeout);
  });
</script>
