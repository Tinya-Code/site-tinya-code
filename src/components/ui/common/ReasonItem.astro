---
import Icon from "./Icon.astro";

interface Props {
  title: string;
  description: string;
  icon: string;
}

const { title, description, icon } = Astro.props;
---

<div class="flex items-start gap-4">
  <Icon name={icon} size={6} class="text-brand mt-0.5 shrink-0" />
  <div class="space-y-1">
    <h3 class="font-poppins font-semibold text-base text-dark">
      {title}
    </h3>
    <p class="font-poppins text-sm text-gray leading-relaxed mt-1">
      {description}
    </p>
  </div>
</div>
