---
import Icon from "./Icon.astro";
import Image from "astro/components/Image.astro";
interface Link {
  text: string;
  href: string;
}

interface SocialLink {
  label: string;
  href: string;
  icon: string;
}

interface ContactData {
  email: string;
  phone: string;
  address: string;
}

interface Props {
  footerLinks: {
    main: Link[];
    company: Link[];
    legal: Link[];
  };
  siteName: string;
  siteDescription: string;
  socialLinks: SocialLink[];
  contactData: ContactData;
  footerColumns: {
    services: string;
    company: string;
    contact: string;
  };
  copyrightText: string;
}

const {
  footerLinks,
  siteName,
  siteDescription,
  socialLinks,
  contactData,
  footerColumns,
  copyrightText,
} = Astro.props;

const currentYear = new Date().getFullYear();
---

<footer class="bg-dark text-light pt-12 pb-8 border-t border-accent/20">
  <div class="container-main grid grid-cols-1 md:grid-cols-4 gap-8">
    <!-- Brand & Social -->
    <div class="space-y-2 ">
      <a href="/" class="flex flex-col justify-center  items-center " aria-label={`Ir a inicio - ${siteName}`}>
             <Image
        src={"/logoblanco1.svg"}
        alt="logo tinya code"
        width={ 100}
        height={ 20}
        
      />
       <span class="font-rader text-3xl font-bold tracking-tight text-white">
          {siteName}
        </span>
      </a>
      <p class="font-poppins text-sm text-light/60 max-w-xs leading-relaxed">
        {siteDescription}
      </p>
      <div class="flex gap-4">
        {
          socialLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-accent text-light transition-colors duration-200"
              aria-label={link.label}
            >
              <Icon name={link.icon} size={5} ariaHidden={true} />
            </a>
          ))
        }
      </div>
    </div>

    <!-- Quick Links -->
    <nav aria-label="Enlaces de servicios">
      <h3 class="font-poppins text-xs font-semibold text-light/50 uppercase tracking-widest mb-4">
        {footerColumns.services}
      </h3>
      <ul class="space-y-4">
        {
          footerLinks.main.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-animated font-poppins text-sm hover:text-accent text-light transition-colors duration-200"
              >
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Company Links -->
    <nav aria-label="Enlaces de empresa">
      <h3 class="font-poppins text-xs font-semibold text-light/50 uppercase tracking-widest mb-4">
        {footerColumns.company}
      </h3>
      <ul class="space-y-4">
        {
          footerLinks.company.map((link) => (
            <li>
              <a
                href={link.href}
                class="link-animated font-poppins text-sm text-light hover:text-accent transition-colors duration-200"
              >
                {link.text}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Contact Info -->
    <div>
      <h3 class="font-poppins text-xs font-semibold text-light/50 uppercase tracking-widest mb-4">
        {footerColumns.contact}
      </h3>
      <ul class="space-y-4 text-light/70">
        <li class="flex items-start gap-3">
          <Icon name="mdi:email-outline" size={5} class="text-light mt-0.5" ariaHidden={true} />
          <span class="font-poppins text-sm">{contactData.email}</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="mdi:phone-outline" size={5} class="text-light mt-0.5" ariaHidden={true} />
          <span class="font-poppins text-sm">{contactData.phone}</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon
            name="mdi:map-marker-outline"
            size={5}
            class="text-light mt-0.5"
            ariaHidden={true}
          />
          <span class="font-poppins text-sm">{contactData.address}</span>
        </li>
      </ul>
    </div>
  </div>

  <div
    class="container-main mt-16 pt-8 border-t border-accent/20 flex flex-col md:flex-row justify-between items-center gap-4"
  >
    <p class="font-poppins text-xs text-light">
      &copy; {currentYear}
      {siteName}. {copyrightText}
    </p>
    <nav class="flex gap-6" aria-label="Enlaces legales">
      {
        footerLinks.legal.map((link) => (
          <a
            href={link.href}
            class="link-animated font-poppins text-xs hover:text-accent text-light transition-colors duration-200"
          >
            {link.text}
          </a>
        ))
      }
    </nav>
  </div>
</footer>
