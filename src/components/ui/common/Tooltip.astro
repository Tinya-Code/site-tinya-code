---
import Icon from "./Icon.astro";

interface Props {
  text: string;
  iconName?: string;
  iconSize?: 2 | 3 | 4 | 5 | 6 | 7 | 8 | 10 | 12 | 16;
  position?: "top" | "bottom";
  className?: string;
}

const {
  text,
  iconName = "mdi:information-outline",
  iconSize = 4,
  position = "top",
  className = "",
} = Astro.props;
---

<div class:list={["tooltip-container relative inline-flex items-center group", className]}>
  <button
    type="button"
    class="tooltip-trigger group/trigger flex items-center justify-center p-1 text-gray/40 hover:text-brand transition-all focus:outline-none focus:ring-2 focus:ring-brand/30 rounded-full cursor-help"
    aria-label={text}
  >
    <slot name="trigger">
      <Icon name={iconName} size={iconSize} class="group-hover/trigger:scale-110 transition-transform" />
    </slot>
  </button>

  <div
    class:list={[
      "tooltip-box absolute left-1/2 -translate-x-1/2 w-48 p-3 bg-dark text-white text-[11px] leading-tight rounded-sm opacity-0 invisible translate-y-1 transition-all duration-200 z-[100] pointer-events-none shadow-xl",
      "group-hover:visible group-hover:opacity-100 group-hover:translate-y-0",
      "group-[.is-visible]:visible group-[.is-visible]:opacity-100 group-[.is-visible]:translate-y-0",
      position === "top" ? "bottom-full mb-3" : "top-full mt-3",
    ]}
  >
    <div class="relative z-10 text-center">
      {text}
    </div>
    {/* Arrow */}
    <div
      class:list={[
        "absolute left-1/2 -translate-x-1/2 border-8 border-transparent transition-all duration-200",
        position === "top"
          ? "top-full border-t-dark"
          : "bottom-full border-b-dark",
      ]}
    >
    </div>
  </div>
</div>

<script>
  const initTooltips = () => {
    const containers = document.querySelectorAll('.tooltip-container');
    
    containers.forEach(container => {
      const trigger = container.querySelector('.tooltip-trigger');
      
      if (!trigger) return;

      trigger.addEventListener('click', (e) => {
        // Toggle behavior for all devices on click, but especially mobile
        e.stopPropagation();
        
        // Close other tooltips first
        document.querySelectorAll('.tooltip-container.is-visible').forEach(open => {
          if (open !== container) open.classList.remove('is-visible');
        });

        container.classList.toggle('is-visible');
      });
    });

    // Close when clicking outside
    document.addEventListener('click', () => {
       document.querySelectorAll('.tooltip-container.is-visible').forEach(open => {
          open.classList.remove('is-visible');
        });
    });
  };

  // Initial run
  initTooltips();

  // Handle View Transitions
  document.addEventListener("astro:after-swap", initTooltips);
</script>
