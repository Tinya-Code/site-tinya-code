---

<div class="blog-content prose-blog" id="blog-content">
  <slot />
</div>

<script>
  import { blogTerms } from "@/data/blogTerms";

  function initFormatter(): void {
    const container = document.getElementById("blog-content");
    if (!container) return;

    const forbiddenTags = ["CODE", "PRE", "A", "H1", "H2", "H3", "H4", "MARK", "SPAN"];

    const escapeRegex = (str: string): string => {
      return str.replace(/[.*+?^${}()|[\]\\]/g, "\\$&");
    };

    const sortedTerms = [...blogTerms].sort((a, b) => b.term.length - a.term.length);
    const transformedInParagraph = new Set<string>();

    const processTextNode = (node: Text): void => {
      const parent = node.parentNode as HTMLElement;
      if (!parent || forbiddenTags.includes(parent.nodeName)) return;

      const text = node.nodeValue;
      if (!text || !text.trim()) return;

      let newHtml = text;
      let replaced = false;

      // Track reset by checking if parent is a block element that starts a new structural context
      const isNewContext =
        parent.nodeName === "P" || parent.nodeName === "LI" || parent.nodeName === "DIV";
      if (isNewContext && !parent.hasAttribute("data-terms-processed")) {
        transformedInParagraph.clear();
        parent.setAttribute("data-terms-processed", "true");
      }

      for (const item of sortedTerms) {
        const termKey = item.term.toLowerCase();
        if (transformedInParagraph.has(termKey)) continue;

        const flags = item.caseSensitive ? "g" : "gi";
        const regex = new RegExp(`\\b(${escapeRegex(item.term)})\\b`, flags);
        const match = text.match(regex);

        if (match) {
          replaced = true;
          transformedInParagraph.add(termKey);

          let replacement = "";
          if (item.type === "internal-link" || item.type === "external-link") {
            const target =
              item.type === "external-link" ? ' target="_blank" rel="noopener noreferrer"' : "";
            replacement = `<a href="${item.href}" class="blog-internal-link"${target}>${match}</a>`;
          } else if (item.type === "highlight") {
            replacement = `<mark class="blog-highlight">${match}</mark>`;
          } else if (item.type === "definition") {
            replacement = `<span class="blog-definition" tabindex="0" data-definition="${item.definition}">${match[1]}</span>`;
          }

          newHtml = text.replace(regex, replacement);
          break;
        }
      }

      if (replaced) {
        const span = document.createElement("span");
        span.innerHTML = newHtml;
        parent.replaceChild(span, node);
      }
    };

    const walkTextNodes = (root: Element): void => {
      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {
        acceptNode: function (node: Node) {
          const parent = node.parentNode as Element;
          if (parent && forbiddenTags.includes(parent.nodeName)) {
            // Standard TreeWalker doesn't reject subtree for text nodes, so we just filter specific text nodes
            return NodeFilter.FILTER_REJECT;
          }
          return NodeFilter.FILTER_ACCEPT;
        },
      });

      const textNodes: Text[] = [];
      let currentNode = walker.nextNode();
      while (currentNode) {
        textNodes.push(currentNode as Text);
        currentNode = walker.nextNode();
      }

      textNodes.forEach((node) => processTextNode(node));
    };

    walkTextNodes(container);
  }

  // Initial runs
  initFormatter();

  // Handle View Transitions
  document.addEventListener("astro:after-swap", initFormatter);
</script>

<style is:global>
  .blog-internal-link {
    color: var(--color-brand);
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.2s;
  }
  .blog-internal-link:hover {
    opacity: 0.8;
  }
  .blog-internal-link::after {
    content: " →";
    font-size: 0.8em;
  }

  .blog-highlight {
    background-color: color-mix(in srgb, var(--color-brand) 15%, transparent);
    color: var(--color-dark);
    padding: 0 4px;
    border-radius: 2px;
  }

  .blog-definition {
    border-bottom: 2px dotted var(--color-brand);
    cursor: help;
    position: relative;
    font-weight: 500;
  }

  .blog-definition:hover::after,
  .blog-definition:focus::after {
    content: attr(data-definition);
    position: absolute;
    bottom: 125%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-dark);
    color: white;
    padding: 8px 12px;
    border-radius: 6px;
    font-size: 12px;
    width: max-content;
    max-width: 200px;
    white-space: normal;
    z-index: 50;
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
  }
</style>
