---
import { Icon } from "astro-icon/components";

interface Props {
  href: string;
  label: string;
  icon?: string;
  class?: string;
  isHistory?: boolean;
}

const { href, label, icon = "mdi:arrow-left", class: className, isHistory = true } = Astro.props;
---

<div class:list={["mb-8 container-main", className]}>
  <a
    href={href}
    class:list={[
      "inline-flex items-center gap-2 text-dark/60 hover:text-brand font-poppins text-xs font-bold uppercase tracking-widest transition-colors group/back",
      isHistory && "back-button-history"
    ]}
  >
    <Icon
      name={icon}
      class="size-4 group-hover/back:-translate-x-1 transition-transform"
    />
    {label}
  </a>
</div>

<script>
  function setupBackButtons() {
    const backButtons = document.querySelectorAll('.back-button-history');
    backButtons.forEach(btn => {
      btn.addEventListener('click', (e) => {
        // Only use history.back() if there's a referrer from the same site
        const hasReferrer = document.referrer && document.referrer.includes(window.location.host);
        
        if (hasReferrer) {
          e.preventDefault();
          window.history.back();
        }
      });
    });
  }

  // Initial setup
  setupBackButtons();
  
  // Handle View Transitions
  document.addEventListener('astro:after-swap', setupBackButtons);
</script>
