---
import Icon from "../common/Icon.astro";
import Button from "@/components/ui/buttons/Button.astro";
import type { CardBase } from "@/types";

interface Props extends Omit<CardBase, "image" | "href"> {
  id: string;
  name:string;
  priceMonthly: number;
  priceAnnual: number;
  period: string;
  features: (string | { text: string; tooltip: string })[];
  ctaLabel?: string;
  ctaHref: string;
  featured?: boolean;
  badge?: string;
}

const {
  id,
   name,
  priceMonthly,
  priceAnnual,
  period,
  description,
  features,
  ctaLabel = "Solicitar ahora",
  ctaHref,
  featured = false,
  badge,
} = Astro.props;

// Formateador de moneda
const formatPrice = (p: number) => `S/ ${p.toLocaleString("es-PE")}`;
---

<div
  class:list={[
    "pricing-card relative flex flex-col h-full bg-white rounded-sm transition-all duration-500",
    featured
      ? "pricing-card--featured border-2 border-brand z-10 lg:-mt-6 lg:mb-6 shadow-sm"
      : "border border-gray-light",
  ]}
  data-plan-id={id}
  data-price-monthly={priceMonthly}
  data-price-annual={priceAnnual}
>
  {
    (featured || badge) && (
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 badge !bg-brand !text-white !px-4 !py-1.5 whitespace-nowrap">
        {badge || "Recomendado"}
      </div>
    )
  }

  <div class="p-6 flex flex-col h-full">
    <div class="mb-6">
      <h3 class="font-rader  italic  text-4xl text-center text-dark mb-2">{name}</h3>
      <p class="font-poppins text-sm text-gray leading-relaxed">{description}</p>
    </div>

    <div class="mb-8">
      <div class="flex items-baseline gap-1">
        <span
          class="pricing-card__price font-rader text-4xl italic text-dark transition-all duration-300"
        >
          {formatPrice(priceMonthly)}
        </span>
        <span class="pricing-card__period text-sm font-medium text-dark/40">
          /{period}
        </span>
      </div>
      {
        priceAnnual > 0 && (
          <p class="pricing-card__annual-note text-xs text-brand font-semibold mt-1 opacity-0 transition-opacity duration-300">
            Descuento Pagando Completo 
          </p>
        )
      }
    </div>

    <ul class="flex flex-col gap-3   flex-grow">
      {
        features.map((feature) => {
          const isObject = typeof feature === 'object';
          const text = isObject ? feature.text : feature;
          const tooltip = isObject ? feature.tooltip : null;

          return (
            <li class="flex items-start gap-2 font-poppins text-sm text-gray relative group/feature">
              <Icon name="mdi:check" size={4} class="text-brand mt-0.5 shrink-0" ariaHidden={true} />
              <div class="flex items-center gap-1.5 leading-snug">
                <span>{text}</span>
                {tooltip && (
                  <div class="relative flex items-center">
                    <button
                      type="button"
                      class="tooltip-trigger flex items-center justify-center p-0.5 text-gray/40 hover:text-brand transition-colors focus:outline-none"
                      aria-label={`Más información sobre ${text}`}
                      data-tooltip={tooltip}
                    >
                      <Icon name="mdi:information-outline" size={3} />
                    </button>
                    
                    {/* Tooltip Card (Desktop Hover / Mobile Click via JS) */}
                    <div class="tooltip-box absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-48 p-3 bg-dark text-white text-[11px] leading-tight rounded-sm opacity-0 translate-y-2 transition-all duration-200 z-50 pointer-events-none group-hover/feature:lg:opacity-100 group-hover/feature:lg:visible group-hover/feature:lg:translate-y-0">
                      {tooltip}
                      {/* Arrow */}
                      <div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-dark"></div>
                    </div>
                  </div>
                )}
              </div>
            </li>
          );
        })
      }
    </ul>

    <Button
      variant="primary"
      class="pricing-modal-trigger w-full justify-center py-4 font-bold tracking-wide mt-8"
      data-plan-name={name}
    >
      {ctaLabel}
    </Button>
  </div>
</div>

<style>
  .pricing-card {
    border-radius: var(--radius-sm, 2px);
  }

  .pricing-card--featured {
    transform: scale(1.02);
  }

  /* Tooltip logic for mobile/JS */
  .tooltip-box {
    visibility: hidden;
  }

  .tooltip-box.is-visible,
  .group\/feature:hover .tooltip-box {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  @media (max-width: 1023px) {
    .pricing-card--featured {
      transform: none;
    }
  }
</style>

<script>
  // Mobile Tooltip Logic: Tap to toggle
  const initTooltips = () => {
    const triggers = document.querySelectorAll('.tooltip-trigger');
    
    triggers.forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const box = trigger.nextElementSibling;
        if (!box) return;

        // Close others
        document.querySelectorAll('.tooltip-box').forEach(b => {
          if (b !== box) b.classList.remove('is-visible');
        });

        box.classList.toggle('is-visible');
      });
    });

    // Close on click outside
    document.addEventListener('click', () => {
      document.querySelectorAll('.tooltip-box').forEach(b => b.classList.remove('is-visible'));
    });
  };

  // Initial run
  initTooltips();

  // Handle View Transitions
  document.addEventListener("astro:after-swap", initTooltips);
</script>
