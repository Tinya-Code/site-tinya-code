---
import Tooltip from "../common/Tooltip.astro";
import Icon from "../common/Icon.astro";
import Button from "@/components/ui/buttons/Button.astro";
import type { PricingPlan } from "@/types";

interface Props extends PricingPlan {}

const {
  id,
  name,
  priceSplit,
  priceFull,
  period,
  description,
  features,
  ctaLabel = "Solicitar ahora",
  ctaHref,
  featured = false,
  badge,
  hideDiscount = false,
  customDiscountLabel,
} = Astro.props;

// Formateador de moneda
const formatPrice = (p: number | string) => {
  if (typeof p === "string") return p;
  return `S/ ${p.toLocaleString("es-PE")}`;
};
---

<div
  class:list={[
    "pricing-card relative flex flex-col h-full bg-white rounded-sm transition-all duration-500",
    featured
      ? "pricing-card--featured border-2 border-brand z-10 lg:-mt-6 lg:mb-6 shadow-sm"
      : "border border-gray-light",
  ]}
  data-plan-id={id}
  data-price-split={priceSplit}
  data-price-full={priceFull}
>
  {
    (featured || badge) && (
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 badge !bg-brand !text-white !px-4 !py-1.5 whitespace-nowrap">
        {badge || "Recomendado"}
      </div>
    )
  }

  <div class="p-6 flex flex-col h-full">
    <div class="mb-6">
      <h3 class="font-rader  italic  text-4xl text-center text-dark mb-2">{name}</h3>
      <p class="font-poppins text-sm text-gray leading-relaxed">{description}</p>
    </div>

    <div class="mb-8">
      <div class="flex items-baseline gap-1">
        <span
          class="pricing-card__price font-rader text-4xl italic text-dark transition-all duration-300"
        >
          {formatPrice(priceSplit)}
        </span>
        <span class="pricing-card__period text-sm font-medium text-dark/40 flex items-center gap-1">
          /{period}
          {period === "pago único" && (
            <Tooltip text="Inversión total por el proyecto completado. Sin mensualidades." iconSize={3} />
          )}
          {period === "proyecto" && (
            <Tooltip text="El costo final depende de la complejidad y requerimientos específicos." iconSize={3} />
          )}
        </span>
      </div>
      {
        !hideDiscount && typeof priceFull === "number" && priceFull > 0 && (
          <p class="pricing-card__annual-note text-xs text-brand font-semibold mt-1 opacity-0 transition-opacity duration-300">
            Descuento Pagando Completo 
          </p>
        )
      }
    </div>

    <ul class="flex flex-col gap-3   flex-grow">
      {
        features.map((feature) => {
          const isObject = typeof feature === 'object';
          const text = isObject ? feature.text : feature;
          const tooltip = isObject ? feature.tooltip : null;

          return (
            <li class="flex items-start gap-2 font-poppins text-sm text-gray relative group/feature">
              <Icon name="mdi:check" size={4} class="text-brand mt-0.5 shrink-0" ariaHidden={true} />
              <div class="flex items-center gap-1.5 leading-snug">
                <span>{text}</span>
                {tooltip && (
                  <Tooltip text={tooltip} iconSize={3} />
                )}
              </div>
            </li>
          );
        })
      }
    </ul>

    <Button
      variant="primary"
      class="pricing-modal-trigger w-full justify-center py-4 font-bold tracking-wide mt-8"
      data-plan-name={name}
    >
      {ctaLabel}
    </Button>
  </div>
</div>

<style>
  .pricing-card {
    border-radius: var(--radius-sm, 2px);
  }

  .pricing-card--featured {
    transform: scale(1.02);
  }

  @media (max-width: 1023px) {
    .pricing-card--featured {
      transform: none;
    }
  }
</style>
