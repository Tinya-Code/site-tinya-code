---
import Icon from "../common/Icon.astro";
import Button from "@/components/ui/buttons/Button.astro";
import type { CardBase } from "@/types";

interface Props extends Omit<CardBase, "image" | "href"> {
  id: string;
  name:string;
  priceMonthly: number;
  priceAnnual: number;
  period: string;
  features: string[];
  ctaLabel?: string;
  ctaHref: string;
  featured?: boolean;
  badge?: string;
}

const {
  id,
   name,
  priceMonthly,
  priceAnnual,
  period,
  description,
  features,
  ctaLabel = "Solicitar ahora",
  ctaHref,
  featured = false,
  badge,
} = Astro.props;

// Formateador de moneda
const formatPrice = (p: number) => `S/ ${p.toLocaleString("es-PE")}`;
---

<div
  class:list={[
    "pricing-card relative flex flex-col h-full bg-white rounded-sm transition-all duration-500",
    featured
      ? "pricing-card--featured border-2 border-brand z-10 lg:-mt-6 lg:mb-6 shadow-sm"
      : "border border-gray-light",
  ]}
  data-plan-id={id}
  data-price-monthly={priceMonthly}
  data-price-annual={priceAnnual}
>
  {
    (featured || badge) && (
      <div class="absolute -top-3 left-1/2 -translate-x-1/2 badge !bg-brand !text-white !px-4 !py-1.5 whitespace-nowrap">
        {badge || "Recomendado"}
      </div>
    )
  }

  <div class="p-6 flex flex-col h-full">
    <div class="mb-6">
      <h3 class="font-rader  italic  text-4xl text-center text-dark mb-2">{name}</h3>
      <p class="font-poppins text-sm text-gray leading-relaxed">{description}</p>
    </div>

    <div class="mb-8">
      <div class="flex items-baseline gap-1">
        <span
          class="pricing-card__price font-rader text-4xl italic text-dark transition-all duration-300"
        >
          {formatPrice(priceMonthly)}
        </span>
        <span class="pricing-card__period text-sm font-medium text-dark/40">
          /{period}
        </span>
      </div>
      {
        priceAnnual > 0 && (
          <p class="pricing-card__annual-note text-xs text-brand font-semibold mt-1 opacity-0 transition-opacity duration-300">
            Descuento Pagando Completo 
          </p>
        )
      }
    </div>

    <ul class="flex flex-col gap-3 mt-6 mb-8 flex-grow">
      {
        features.map((feature) => (
          <li class="flex items-start gap-2 font-poppins text-sm text-gray">
            <Icon name="mdi:check" size={4} class="text-brand mt-0.5 shrink-0" ariaHidden={true} />
            <span class="leading-snug">{feature}</span>
          </li>
        ))
      }
    </ul>

    <Button
      href={ctaHref}
      variant="primary"
      class="w-full justify-center py-4 font-bold tracking-wide mt-8"
    >
      {ctaLabel}
    </Button>
  </div>
</div>

<style>
  .pricing-card {
    border-radius: var(--radius-sm, 2px);
  }

  .pricing-card--featured {
    transform: scale(1.02);
  }

  @media (max-width: 1023px) {
    .pricing-card--featured {
      transform: none;
    }
  }
</style>
