---
import { Image } from "astro:assets";
import Icon from "../common/Icon.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  featured?: boolean;
}

const { post, featured: featuredProp } = Astro.props;
const { category, readingTime, title, date, heroImage } = post.data;
const featured = featuredProp ?? post.data.featured;
---

<article
  class:list={[
    "group relative overflow-hidden transition-all duration-500 rounded-sm border border-white/10",
    featured ? "blog-bento-featured" : "blog-bento-secondary",
    "flex flex-col md:block",
  ]}
>
  <a href={`/blog/${post.id}/`} class="block w-full h-full relative">
    <!-- Image -->
    <div
      class:list={[
        "relative overflow-hidden w-full h-full",
        featured ? "aspect-square md:aspect-auto" : "aspect-video md:aspect-auto",
      ]}
    >
      <Image
        src={heroImage || "/generico.jpeg"}
        alt={title}
        width={featured ? 1200 : 800}
        height={featured ? 800 : 600}
        class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      />

      <!-- Gradient Overlay -->
      <div
        class="absolute inset-0 bg-gradient-to-t from-dark/95 via-dark/20 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"
      >
      </div>
    </div>

    <!-- Category Tag -->
    <span
      class="absolute top-6 left-6 z-10 badge-accent bg-white/10 backdrop-blur-md text-white border border-white/20 text-[10px] py-1 px-3"
    >
      {category}
    </span>

    <!-- Content -->
    <div class="absolute inset-0 p-6 md:p-8 flex flex-col justify-end">
      <div
        class="space-y-3 translate-y-4 group-hover:translate-y-0 transition-transform duration-500"
      >
        <h3
          class:list={[
            "font-poppins font-bold text-white tracking-tight leading-tight",
            featured ? "text-2xl md:text-3xl" : "text-lg md:text-xl",
          ]}
        >
          {title}
        </h3>

        <div
          class="flex items-center gap-4 font-poppins text-[10px] font-medium text-white/60 uppercase tracking-widest"
        >
          <div class="flex items-center gap-1.5">
            <Icon name="mdi:calendar-month-outline" size={4} />
            {date.toLocaleDateString("es-PE", { month: "short", year: "numeric" })}
          </div>
          <div class="flex items-center gap-1.5">
            <Icon name="mdi:clock-outline" size={4} />
            {readingTime} min lectura
          </div>
        </div>
      </div>
    </div>
  </a>
</article>
