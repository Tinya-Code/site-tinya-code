---
import Icon from "../common/Icon.astro";


interface Props {
  name: string;
  role: string;
  company: string;
  content: string;
  avatar: string;
  rating?: number;
}

const { name, role, company, content, avatar, rating = 5 } = Astro.props;
---

<div class="group relative flex flex-col gap-6 p-7 sm:p-8 overflow-hidden
            bg-white hover:bg-gray-50/80
            transition-colors duration-500">

  <!-- Esquinas geométricas decorativas -->
  <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-brand/30 group-hover:border-brand/50 group-hover:w-10 group-hover:h-10 transition-all duration-500 rounded-tl-sm pointer-events-none"></div>
  <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-brand/30 group-hover:border-brand/50 group-hover:w-10 group-hover:h-10 transition-all duration-500 rounded-br-sm pointer-events-none"></div>

  <!-- Comilla tipográfica decorativa -->
  <div class="absolute -top-1 right-7 font-poppins font-extrabold text-[7rem] leading-none text-brand/20 group-hover:text-brand/10 transition-colors duration-500 select-none pointer-events-none">
    "
  </div>

  <!-- Testimonio -->
  <blockquote class="relative z-10 flex-grow">
    <p class="font-poppins text-sm sm:text-[0.9375rem] text-gray leading-[1.8] tracking-wide">
      {content}
    </p>
  </blockquote>

  <!-- Separador con acento brand -->
  <div class="relative flex items-center gap-3">
    <div class="w-2 h-2 rotate-45 bg-brand/30 group-hover:bg-brand/60 transition-colors duration-300 shrink-0"></div>
    <div class="h-px flex-1 bg-gradient-to-r from-brand/20 to-transparent"></div>
  </div>

  <!-- Autor -->
  <div class="relative z-10 flex items-center gap-4">

    <!-- Avatar con marco geométrico -->
    <div class="relative shrink-0">
      <div class="absolute -inset-1 rounded-full border border-brand/20 group-hover:border-brand/40 group-hover:scale-105 transition-all duration-400"></div>
      <div class="size-11 sm:size-12 rounded-full overflow-hidden relative z-10">
        <img
          src={avatar}
          alt={name}
          width={96}
          height={96}
          class="w-full h-full object-cover grayscale-[20%] group-hover:grayscale-0 transition-all duration-500"
        />
      </div>
    </div>

    <!-- Info -->
    <div class="flex flex-col gap-1 min-w-0">
      <cite class="not-italic font-poppins font-bold text-sm sm:text-base text-dark leading-none tracking-tight truncate">
        {name}
      </cite>
      <div class="flex items-center gap-1.5 flex-wrap">
        <span class="font-poppins text-[11px] text-brand font-semibold uppercase tracking-widest leading-none">
          {company}
        </span>
        <span class="w-1 h-1 rounded-full bg-gray/30 shrink-0"></span>
        <span class="font-poppins text-[11px] text-gray/60 leading-none truncate">
          {role}
        </span>
      </div>
    </div>

  </div>

</div>