---
import { reasons } from "@/data/reasons";
import ReasonItem from "@/components/ui/common/ReasonItem.astro";
---

<div class="relative w-full">

  <!-- Grid con separadores geométricos -->
  <ul class="grid grid-cols-1 sm:grid-cols-2 divide-y sm:divide-y-0 sm:divide-x divide-gray-100">
    {
      reasons.map((reason, index) => (
        <li
          class="animate-on-scroll relative"
          style={`transition-delay: ${index * 100}ms`}
        >
          <!-- Separador horizontal en mobile para la segunda fila -->
          {index === 2 && (
            <div class="hidden sm:block absolute top-0 left-0 right-0 border-t border-gray-100" />
          )}
          <ReasonItem {...reason} />
        </li>
      ))
    }
  </ul>

 

</div>

<script>
  import { initScrollAnimations } from "@/scripts/observer";
  initScrollAnimations();
  document.addEventListener("astro:after-swap", initScrollAnimations);
</script>