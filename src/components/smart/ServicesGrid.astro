---
import { services } from "@/data/services";
import ServiceCard from "@/components/ui/cards/ServiceCard.astro";

// Smart component that fetches data and renders the grid
const categories = ["all", "web", "software", "automatizacion"];
---

<div class="space-y-12">
  <!-- Tabs -->
  <div
    class="flex items-center justify-center gap-3 overflow-x-auto pb-6 -mx-4 px-4 sm:mx-0 sm:px-0 scrollbar-hide"
    role="tablist"
    aria-label="Filtrar servicios por categoría"
  >
    <button
      class="chip-sector active whitespace-nowrap"
      data-category="all"
      role="tab"
      aria-selected="true"
    >
      <span class="font-poppins text-xs font-semibold uppercase tracking-widest">Todos</span>
    </button>
    {
      categories
        .filter((c) => c !== "all")
        .map((cat) => (
          <button
            class="chip-sector whitespace-nowrap"
            data-category={cat}
            role="tab"
            aria-selected="false"
          >
            <span class="font-poppins text-xs font-semibold uppercase tracking-widest">
              {cat === "web" ? "Web" : cat === "software" ? "Software" : "Automatización"}
            </span>
          </button>
        ))
    }
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 min-h-[400px]">
    {
      services.map((service, index) => (
        <div
          class="service-card-item animate-on-scroll"
          data-category={service.category}
          style={`transition-delay: ${index * 50}ms`}
        >
          <ServiceCard {...service} />
        </div>
      ))
    }
  </div>
</div>

<script>
  import { initFilter, initScrollAnimations } from "@/scripts/observer";

  // Initialize Filtering
  initFilter('[data-category][role="tab"]', ".service-card-item", "category");

  // --- Expansion Logic (Desktop Only) ---
  const serviceCards = document.querySelectorAll<HTMLElement>("[data-service-card]");
  const isDesktop = (): boolean => window.innerWidth >= 1024;

  serviceCards.forEach((card) => {
    card.addEventListener("click", (e: MouseEvent) => {
      if (!isDesktop()) return;

      // Prevent navigation if clicking the card but not a direct link
      const target = e.target as HTMLElement;
      if (target.closest("a")) return;

      const isOpen = card.classList.contains("is-open");

      // Close all other cards
      serviceCards.forEach((c) => c.classList.remove("is-open"));

      if (!isOpen) {
        card.classList.add("is-open");
      }
    });
  });

  // Re-init observer for filtered items
  initScrollAnimations();

  // Cleanup on swap
  document.addEventListener("astro:before-swap", () => {
    // initFilter and local listeners don't necessarily need cleanup if they don't leak,
    // but it's good practice for complex ones.
  });
</script>
