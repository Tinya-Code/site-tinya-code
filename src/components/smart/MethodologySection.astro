---
import { methodologyContent } from "@/data/methodology";
import Methodology from "@/components/ui/sections/Methodology.astro";
import SectionHeader from "@/components/ui/sections/SectionHeader.astro";
import { siteConfig } from "@/data/siteConfig";

const { title, subtitle } = siteConfig.home.methodology;

interface Props {
  color?: "light" | "dark" | "white";
}

const { color = "light" } = Astro.props;

const isDark = color === "dark";
---

<section class:list={["section-base py-12", `section-${color}`]}>
  <div class="container-main space-y-8">
    <SectionHeader title={title} subtitle={subtitle} variant={color} />
    <Methodology
      phases={methodologyContent}
      autoplayMs={10000}
      dark={isDark}
    />
  </div>
</section>

<script>
  import { initScrollAnimations } from "@/scripts/observer";
  initScrollAnimations();
  document.addEventListener("astro:after-swap", initScrollAnimations);
</script>