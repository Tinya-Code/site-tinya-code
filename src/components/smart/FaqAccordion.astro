---
import { faqs } from "@/data/faq";
import Icon from "@/components/ui/common/Icon.astro";

// Smart component: manages FAQ data, search, and filtering
const categories = ["todos", "general", "proceso", "precios", "tecnico"];
---

<section class="section-base section-light py-16 md:py-24">
  <div class="container-main max-w-4xl mx-auto">
    <!-- Interactive Header -->
    <div class="space-y-12 mb-16 animate-on-scroll">
      <!-- Search Bar -->
      <div class="relative max-w-xl mx-auto group">
        <div class="absolute inset-y-0 left-5 flex items-center pointer-events-none">
          <Icon
            name="mdi:magnify"
            size={5}
            class="text-gray group-focus-within:text-brand transition-colors"
          />
        </div>
        <input
          type="text"
          id="faq-search"
          placeholder="¿En qué podemos ayudarte?"
          class="w-full pl-14 pr-6 py-4 bg-white border border-gray-light rounded-sm font-poppins text-sm text-dark placeholder:text-gray focus:outline-none focus:border-brand transition-colors duration-200"
        />
      </div>

      <!-- Category Tabs (Chips) -->
      <div class="flex flex-wrap items-center justify-center gap-3">
        {
          categories.map((cat) => (
            <button
              class:list={[
                "flex items-center gap-2 border border-gray-light rounded-sm px-4 py-2 bg-white hover:border-brand hover:text-brand transition-colors duration-200 cursor-pointer",
                "font-poppins text-sm font-medium text-dark capitalize",
                cat === "todos" && "border-brand text-brand bg-brand/5",
              ]}
              data-category-tab={cat}
              role="tab"
              aria-selected={cat === "todos" ? "true" : "false"}
            >
              {cat}
            </button>
          ))
        }
      </div>
    </div>

    <!-- FAQ List - Accordion Pattern -->
    <div class="space-y-0" id="faq-list">
      {
        faqs.map((faq, index) => (
          <div
            class="faq-item border-b border-gray-light animate-on-scroll"
            data-category={faq.category}
            data-question={faq.question.toLowerCase()}
            data-answer={faq.answer.toLowerCase()}
            style={`transition-delay: ${index * 50}ms`}
          >
            <button
              class="faq-trigger w-full flex justify-between items-center py-5 cursor-pointer font-poppins font-semibold text-base text-dark hover:text-brand transition-colors text-left focus:outline-none"
              aria-expanded="false"
            >
              <span class="pr-8">{faq.question}</span>
              <Icon
                name="mdi:chevron-down"
                class="faq-icon size-4 text-gray transition-transform duration-200 shrink-0"
                ariaHidden={true}
              />
            </button>
            <div class="faq-content overflow-hidden transition-all duration-300 max-h-0 opacity-0">
              <p class="font-poppins text-sm text-gray leading-relaxed pb-5">
                {faq.answer}
              </p>
            </div>
          </div>
        ))
      }

      <!-- Empty State -->
      <div id="faq-empty" class="hidden text-center py-20 animate-on-scroll">
        <div
          class="inline-flex items-center justify-center size-20 rounded-sm bg-white border border-gray-light text-gray/40 mb-6"
        >
          <Icon name="mdi:comment-search-outline" class="size-8" />
        </div>
        <div class="space-y-2">
          <h3 class="font-poppins font-semibold text-xl text-dark">Sin resultados</h3>
          <p class="font-poppins text-sm text-gray max-w-xs mx-auto">
            Intenta con otros términos o elige una categoría.
          </p>
        </div>
        <div class="pt-8">
          <a
            href="/contact"
            class="inline-flex items-center gap-1 text-sm font-medium text-brand hover:text-brand-dark transition-colors duration-200"
          >
            Contactar con nosotros
            <Icon name="mdi:arrow-right" class="size-4" />
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .faq-item.is-open .faq-icon {
    color: var(--color-brand);
    transform: rotate(180deg);
  }

  .faq-item.is-open .faq-content {
    max-height: 1000px;
    opacity: 1;
  }

  .faq-item.hidden-by-filter {
    display: none;
  }

  /* Active state for Category Tabs */
  [data-category-tab].active {
    border-color: var(--color-brand);
    color: var(--color-brand);
    background-color: rgba(var(--color-brand-rgb), 0.05);
  }
</style>

<script>
  import { initScrollAnimations, debounce } from "@/scripts/observer";

  const initFaq = (): void => {
    const searchInput = document.querySelector<HTMLInputElement>("#faq-search");
    const tabs = document.querySelectorAll<HTMLButtonElement>("[data-category-tab]");
    const items = document.querySelectorAll<HTMLElement>(".faq-item");
    const emptyState = document.querySelector<HTMLElement>("#faq-empty");
    const triggers = document.querySelectorAll<HTMLButtonElement>(".faq-trigger");

    if (items.length === 0) return;

    let currentCategory = "todos";
    let searchQuery = "";

    const normalizeText = (text: string): string => {
      return text
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .toLowerCase();
    };

    const closeAll = (): void => {
      items.forEach((item) => {
        item.classList.remove("is-open");
        item.querySelector(".faq-trigger")?.setAttribute("aria-expanded", "false");
      });
    };

    const filterFaqs = (): void => {
      let visibleCount = 0;
      const normalizedQuery = normalizeText(searchQuery);

      closeAll();

      items.forEach((item) => {
        const category = item.getAttribute("data-category");
        const question = item.getAttribute("data-question") || "";
        const answer = item.getAttribute("data-answer") || "";

        const matchesCategory = currentCategory === "todos" || category === currentCategory;
        const matchesSearch =
          normalizeText(question).includes(normalizedQuery) ||
          normalizeText(answer).includes(normalizedQuery);

        if (matchesCategory && matchesSearch) {
          item.classList.remove("hidden-by-filter");
          visibleCount++;
        } else {
          item.classList.add("hidden-by-filter");
        }
      });

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount > 0);
      }
    };

    // Search Logic with Debounce
    const handleSearch = debounce((e: Event) => {
      searchQuery = (e.target as HTMLInputElement).value;
      filterFaqs();
    }, 300);
    searchInput?.addEventListener("input", handleSearch);

    // Tab Logic
    const handleTabClick = (tab: HTMLButtonElement) => {
      const cat = tab.getAttribute("data-category-tab") || "todos";
      currentCategory = cat;

      tabs.forEach((t) => {
        const isActive = t === tab;
        t.classList.toggle("active", isActive);
        t.setAttribute("aria-selected", String(isActive));
        
        // Manual styling toggle if not using global classes
        if (isActive) {
          t.classList.add("border-brand", "text-brand", "bg-brand/5");
        } else {
          t.classList.remove("border-brand", "text-brand", "bg-brand/5");
        }
      });

      filterFaqs();
    };

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => handleTabClick(tab));
    });

    // Accordion Logic
    const handleTriggerClick = (trigger: HTMLButtonElement) => {
      const item = trigger.closest(".faq-item") as HTMLElement;
      const isOpen = item.classList.contains("is-open");

      closeAll();

      if (!isOpen) {
        item.classList.add("is-open");
        trigger.setAttribute("aria-expanded", "true");
      }
    };

    const handleKeydown = (e: KeyboardEvent) => {
      if (e.key === "Escape") {
        closeAll();
      }
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("click", () => handleTriggerClick(trigger));
      trigger.addEventListener("keydown", handleKeydown);
    });

    // Cleanup for View Transitions
    document.addEventListener(
      "astro:before-swap",
      () => {
        searchInput?.removeEventListener("input", handleSearch);
        triggers.forEach((trigger) => {
          trigger.removeEventListener("keydown", handleKeydown);
        });
      },
      { once: true },
    );
  };

  // Initial runs
  initFaq();
  initScrollAnimations();

  // Handle View Transitions
  document.addEventListener("astro:after-swap", () => {
    initFaq();
    initScrollAnimations();
  });
</script>
